	<SourceCode>
		<Methods xmlns="">
			<Method>
				<Name>classDeclaration</Name>
				<Source><![CDATA[
[Form]
public class FWFTextBlockSetupGroup extends FormRun
{
    FWFTextBlockModule      module;

}
]]></Source>
			</Method>
			<Method>
				<Name>init</Name>
				<Source><![CDATA[
    public void init()
    {
        super();
    
    
        if (element.args())
        {
            if (element.args().parmEnumType() == enumnum(FWFTextBlockModule))
            {
                module = element.args().parmEnum();
            }
        }
    
        if (module)
        {
            FWFTextBlockSetupGroup_ds.object(fieldNum(FWFTextBlockSetupGroup, Module)).skip(false);
            FWFTextBlockSetupGroup_ds.query().dataSourceTable(tableNum(FWFTextBlockSetupGroup)).addRange(fieldNum(FWFTextBlockSetupGroup, Module)).value(QueryValue(module));

            FormGridControl_Module.visible(false);
            DetailsHeaderGroup_Module.visible(false);
        }
        else
        {
            FWFTextBlockSetupGroup_ds.object(fieldNum(FWFTextBlockSetupGroup, Module)).skip(true);
        }

        element.showSalesPurchFields();
    }

]]></Source>
			</Method>
			<Method>
				<Name>showSalesPurchFields</Name>
				<Source><![CDATA[
    void showSalesPurchFields()
    {
        switch (module)
        {
            case FWFTextBlockModule::Customer :
                PrintOnPurchFormletters.visible(true);
                PrintOnSalesFormletters.visible(true);
                PrintOnProductionReports.visible(false);
                PrintOnProjectReports.visible(false);
                break;
    
            case FWFTextBlockModule::Supplier :
                PrintOnPurchFormletters.visible(true);
                PrintOnSalesFormletters.visible(false);
                PrintOnProductionReports.visible(false);
                PrintOnProjectReports.visible(false);
                break;

            case FWFTextBlockModule::ReleasedProduct :
                PrintOnPurchFormletters.visible(true);
                PrintOnSalesFormletters.visible(true);
                PrintOnProductionReports.visible(true);
                PrintOnProjectReports.visible(true);
                break;

            case FWFTextBlockModule::Project :
                PrintOnPurchFormletters.visible(false);
                PrintOnSalesFormletters.visible(false);
                PrintOnProductionReports.visible(false);
                PrintOnProjectReports.visible(true);
                RelatedOrders.visible(false);
                break;
    
            default:
                PrintOnPurchFormletters.visible(true);
                PrintOnSalesFormletters.visible(true);
                PrintOnProductionReports.visible(true);
                PrintOnProjectReports.visible(true);
                RelatedOrders.visible(true);
                break;
        }
    
    }

]]></Source>
			</Method>
