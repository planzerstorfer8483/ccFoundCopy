}
]]></Source>
			</Method>
			<Method>
				<Name>init</Name>
				<Source><![CDATA[
    /// <summary>
    /// Initializes the form.
    /// </summary>
    public void init()
    {
        Common parentBuffer;

        super();

        // Find buffer type
        parentBuffer = element.args().record();
        if(parentBuffer != null)
        {
            if(parentBuffer is FWFTextBlockLanguage)
            {
                textBlockLanguage = parentBuffer as FWFTextBlockLanguage;

                // Update Html control
                HTMLEditor.parmHtmlContent(textBlockLanguage.editValue());
            }
            else if (parentBuffer is FWFTextBlockInstance)
            {
                textBlockInstance = parentBuffer as FWFTextBlockInstance;

                // Update Html control
                HTMLEditor.parmHtmlContent(textBlockInstance.editValue());
            }
        }
    }

]]></Source>
