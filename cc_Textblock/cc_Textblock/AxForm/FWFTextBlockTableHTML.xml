						<Source><![CDATA[
        /// <summary>
        /// Handles the clicked event of OK button.
        /// </summary>
        public void clicked()
        {
            super();

            if (textBlockLanguage.RecId)
            {
                textBlockLanguage.editValue(true, HTMLEditor.parmHtmlContent());
            }
            else if (textBlockInstance.RecId)
            {
                textBlockInstance.editValue(true, HTMLEditor.parmHtmlContent());
            }
        }

]]></Source>
