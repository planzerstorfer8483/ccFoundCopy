			<Method>
				<Name>findOrCreate</Name>
				<Source><![CDATA[
    public FWFTextBlockUsage findOrCreate()
    {
        FWFTextBlockUsage       textBlockUsage;
        FWFTextBlockSetupParm   textBlockSetupParm;
        container               copyFields = [
                                    fieldNum(FWFTextBlockParm, PrintOnPurchConfirmation),
                                    fieldNum(FWFTextBlockParm, PrintOnPurchPackingSlip),
                                    fieldNum(FWFTextBlockParm, PrintOnPurchReceiptsList),
                                    fieldNum(FWFTextBlockParm, PrintOnPurchInvoice),
                                    fieldNum(FWFTextBlockParm, PrintOnSalesQuotation),
                                    fieldNum(FWFTextBlockParm, PrintOnSalesConfirmation),
                                    fieldNum(FWFTextBlockParm, PrintOnSalesPackingSlip),
                                    fieldNum(FWFTextBlockParm, PrintOnSalesPickingList),
                                    fieldNum(FWFTextBlockParm, PrintOnSalesInvoice),
									fieldNum(FWFTextBlockParm, PrintOnProdJobCard),
                                    fieldNum(FWFTextBlockParm, PrintOnProdRouteCard),
                                    fieldNum(FWFTextBlockParm, PrintOnProdPickList),
                                    fieldNum(FWFTextBlockParm, PrintOnProjQuotation),
                                    fieldNum(FWFTextBlockParm, PrintOnProjQuotationConfirm),
                                    fieldNum(FWFTextBlockParm, PrintOnProjInvoice),
                                    fieldNum(FWFTextBlockParm, PrintOnPurchReq),
                                    fieldNum(FWFTextBlockParm, PrintOnPurchRFQCase)];
        int                     i;
    
        ttsBegin;
    
        select firstonly textBlockUsage
            where textBlockUsage.TextBlockRecId    == FWFTextBlockUsage.TextBlockRecId
               && textBlockUsage.ProductType       == FWFTextBlockUsage.ProductType
               && textBlockUsage.ItemCode          == FWFTextBlockUsage.ItemCode
               && textBlockUsage.ItemRelation      == FWFTextBlockUsage.ItemRelation
               && textBlockUsage.AccountType       == FWFTextBlockUsage.AccountType
               && textBlockUsage.AccountCode       == FWFTextBlockUsage.AccountCode
               && textBlockUsage.AccountRelation   == FWFTextBlockUsage.AccountRelation
               && textBlockUsage.FromDate          == FWFTextBlockUsage.FromDate
         join forUpdate textBlockSetupParm
            where textBlockSetupParm.RecId == textBlockUsage.SetupRefRefId;
    
        if (! textBlockUsage)
        {
            textBlockUsage.initValue();
    
            textBlockUsage.InventDimId = InventDim::inventDimIdBlank();
    
            textBlockUsage.TextBlockRecId    = FWFTextBlockUsage.TextBlockRecId;
            textBlockUsage.ProductType       = FWFTextBlockUsage.ProductType;
            textBlockUsage.ItemCode          = FWFTextBlockUsage.ItemCode;
            textBlockUsage.ItemRelation      = FWFTextBlockUsage.ItemRelation;
            textBlockUsage.AccountType       = FWFTextBlockUsage.AccountType;
            textBlockUsage.AccountCode       = FWFTextBlockUsage.AccountCode;
            textBlockUsage.AccountRelation   = FWFTextBlockUsage.AccountRelation;
    
            textBlockUsage.FromDate          = FWFTextBlockUsage.FromDate;
            textBlockUsage.ToDate            = FWFTextBlockUsage.ToDate;
    
            textBlockSetupParm.initValue();
            textBlockSetupParm.data(FWFTextBlockSetupParm);
            textBlockSetupParm.insert();
    
            textBlockUsage.SetupRefRefId     = textBlockSetupParm.RecId;
    
            if (! textBlockUsage.validateWrite())
            {
                throw error("@SYS93289");
            }
    
            textBlockUsage.insert();
        }
        else
        {
            // merge all marked fields, not only selectedDocumentFldId
            for (i = 1; i <= conLen(copyFields); i++)
            {
                if (FWFTextBlockSetupParm.(conPeek(copyFields, i)))
                {
                    textBlockSetupParm.(conPeek(copyFields, i)) = true;
                }
            }
            textBlockSetupParm.update();
        }
    
        ttsCommit;
    
        return textBlockUsage;
    }

]]></Source>
			</Method>
			<Method>
				<Name>init</Name>
				<Source><![CDATA[
    public void init()
    {
        super();
    
        caller = element.args().record();
        rangeUsage.value(queryValue(caller.RecId));
    
        if (element.args().parmEnumType() == enumNum(AccessType))
        {
            accessType = element.args().parmEnum();
        }
        else
        {
            accessType = AccessType::Edit;
        }
            
        if (accessType == AccessType::Add)
        {
            selectedDocumentFldId = str2int(element.args().parm());
    
            // BP deviation documented
            FWFTextBlockUsage.setTmp();
            FWFTextBlockUsage.setTmpData(element.args().record());
    
            FWFTextBlockSetupParm_ds.allowCreate(true);
            FWFTextBlockSetupParm_ds.create();
            FWFTextBlockSetupParm.(selectedDocumentFldId) = true;
    
            FWFTextBlockTableHeaderVend.parameters('');
            FWFTextBlockTableHeaderCust.parameters('');
            FWFTextBlockTableLines.parameters('');
        }
    }

]]></Source>
			</Method>
			<Method>
				<Name>updateDesign</Name>
				<Source><![CDATA[
    public void updateDesign()
    {
    
    
        if (FWFTextBlockUsage.ProductType == FWFTextBlockProductType::ReleasedProduct)
        {
            module = FWFTextBlockModule::ReleasedProduct;
        }
        else if (FWFTextBlockUsage.AccountType == FWFTextBlockAccountRelationType::Cust)
        {
            module = FWFTextBlockModule::Customer;
        }
        else if (FWFTextBlockUsage.AccountType == FWFTextBlockAccountRelationType::Vend)
        {
            module = FWFTextBlockModule::Supplier;
        }
    
    
        if (FWFTextBlockUsage.AccountType == FWFTextBlockAccountRelationType::Cust)
        {
            Group_AccountRelation.label("@SYS24704");
            PrintOnPurchFormletters.visible(true);
            PrintOnSalesFormletters.visible(true);
            PrintOnProductionReports.visible(false);
        }
        else if (FWFTextBlockUsage.AccountType == FWFTextBlockAccountRelationType::Vend)
        {
            Group_AccountRelation.label("@SYS9455");
            PrintOnPurchFormletters.visible(true);
            PrintOnSalesFormletters.visible(false);
            PrintOnProductionReports.visible(false);
        }
        else if (FWFTextBlockUsage.AccountType == FWFTextBlockAccountRelationType::Prod)
        {
            Group_AccountRelation.label("@SYS135280");
            PrintOnPurchFormletters.visible(true);
            PrintOnSalesFormletters.visible(true);
            PrintOnProductionReports.visible(true);
        }
    
        FWFTextBlockTableLines.visible(module == FWFTextBlockModule::ReleasedProduct);
        FWFTextBlockTableHeaderVend.visible(module == FWFTextBlockModule::Supplier);
        FWFTextBlockTableHeaderCust.visible(module == FWFTextBlockModule::Customer);
    
        this.updateFields();
    
    }

]]></Source>
			</Method>
			<Method>
				<Name>updateFields</Name>
				<Source><![CDATA[
    public void updateFields()
    {
        FWFTextBlockUsage_ds.object(fieldNum(FWFTextBlockUsage, AccountCode)).allowEdit(accessType == accessType::Add);
        FWFTextBlockUsage_ds.object(fieldNum(FWFTextBlockUsage, AccountRelation)).allowEdit(
            accessType == accessType::Add && FWFTextBlockUsage.AccountCode != TableGroupAll::All);
        FWFTextBlockUsage_ds.object(fieldNum(FWFTextBlockUsage, AccountRelation)).skip(
            accessType == accessType::Add && FWFTextBlockUsage.AccountCode != TableGroupAll::All);
    
        FWFTextBlockUsage_ds.object(fieldNum(FWFTextBlockUsage, ItemCode)).allowEdit(accessType == accessType::Add);
        FWFTextBlockUsage_ds.object(fieldNum(FWFTextBlockUsage, ItemRelation)).allowEdit(
            accessType == accessType::Add && FWFTextBlockUsage.ItemCode != TableGroupAll::All);
        FWFTextBlockUsage_ds.object(fieldNum(FWFTextBlockUsage, ItemRelation)).skip(
            accessType == accessType::Add && FWFTextBlockUsage.ItemCode != TableGroupAll::All);
    
        FWFTextBlockUsage_ds.object(fieldNum(FWFTextBlockUsage, ItemCode)).visible(module == FWFTextBlockModule::ReleasedProduct);
        FWFTextBlockUsage_ds.object(fieldNum(FWFTextBlockUsage, ItemRelation)).visible(module == FWFTextBlockModule::ReleasedProduct);
    }

]]></Source>
