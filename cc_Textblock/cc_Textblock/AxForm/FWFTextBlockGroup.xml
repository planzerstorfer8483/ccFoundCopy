			<Method>
				<Name>init</Name>
				<Source><![CDATA[
    public void init()
    {
        super();
    
        if (element.args())
        {
            if (element.args().parmEnumType() == enumnum(FWFTextBlockModule))
            {
                module = element.args().parmEnum();
            }
        }
    
        if (module)
        {
            FWFTextBlockGroup_ds.object(fieldNum(FWFTextBlockGroup, Module)).skip(false);
            FWFTextBlockGroup_ds.query().dataSourceTable(tableNum(FWFTextBlockGroup)).addRange(fieldNum(FWFTextBlockGroup, Module)).value(QueryValue(module));

            Grid_Module.visible(false);

            switch (module)
            {
                case FWFTextBlockModule::Customer :
                    FWFTextBlockGroupAssign_RefId.label("@SYS7149");
                    FWFTextBlockGroupAssign_Name.label("@SYS80991");
                    ReferenceTab.caption("@FWFTextBlock:CaptionCust");
                    break;

                case FWFTextBlockModule::Supplier :
                    FWFTextBlockGroupAssign_RefId.label("@SYS14048");
                    FWFTextBlockGroupAssign_Name.label("@SYS80991");
                    ReferenceTab.caption("@FWFTextBlock:CaptionVend");
                    break;

                case FWFTextBlockModule::ReleasedProduct :
                    FWFTextBlockGroupAssign_RefId.label("@SYS12836");
                    FWFTextBlockGroupAssign_Name.label("@SYS27054");
                    ReferenceTab.caption("@FWFTextBlock:CaptionProd");
                    break;

                case FWFTextBlockModule::Project :
                    FWFTextBlockGroupAssign_RefId.label("@SYS110827");
                    FWFTextBlockGroupAssign_Name.label("@SYS117835");
                    ReferenceTab.caption("@FWFTextBlock:CaptionProj");
                    break;
            }

        }
        else
        {
            FWFTextBlockGroup_ds.object(fieldNum(FWFTextBlockGroup, Module)).skip(true);
        }
    }

]]></Source>
			</Method>
