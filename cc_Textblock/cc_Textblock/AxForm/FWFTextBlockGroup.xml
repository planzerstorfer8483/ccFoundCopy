						<Name>clicked</Name>
						<Source><![CDATA[
        public void clicked()
        {
            MenuFunction    menuFunction;
            Args            args = new Args();

            args.caller(this.formRun());
            args.record(FWFTextBlockGroup);

            switch (module)
            {
                case FWFTextBlockModule::Customer :
                    menuFunction = new MenuFunction(menuItemDisplayStr(FWFTextBlockGroupAdd_Customer), MenuItemType::Display);
                    break;

                case FWFTextBlockModule::Supplier :
                    menuFunction = new MenuFunction(menuItemDisplayStr(FWFTextBlockGroupAdd_Supplier), MenuItemType::Display);
                    break;

                case FWFTextBlockModule::ReleasedProduct :
                    menuFunction = new MenuFunction(menuItemDisplayStr(FWFTextBlockGroupAdd_Product), MenuItemType::Display);
                    break;

                case FWFTextBlockModule::Project :
                    menuFunction = new MenuFunction(menuItemDisplayStr(FWFTextBlockGroupAdd_Project), MenuItemType::Display);
                    break;
            }
            
            if (menuFunction && menuFunction.checkAccessRights())
            {

                menuFunction.run(args);
            }

            super();
        }

]]></Source>
					</Method>
