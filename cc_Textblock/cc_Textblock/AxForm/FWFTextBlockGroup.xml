				<Type>Button</Type>
				<Methods>
					<Method>
						<Name>clicked</Name>
						<Source><![CDATA[
        void clicked()
        {
            super();

            ttsbegin;
            if (FWFTextBlockGroupAssign_ds.anyMarked())
            {
                FWFTextBlockGroupAssign_ds.deleteMarked();
            }
            else if (getFirstSelection(FWFTextBlockGroupAssign_ds))
            {
                FWFTextBlockGroupAssign_ds.delete();
            }
            ttscommit;

            FWFTextBlockGroupAssign_ds.executeQuery();
        }

]]></Source>
