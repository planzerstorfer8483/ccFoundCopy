			<Method>
				<Name>jumpRef</Name>
				<Source><![CDATA[
    public void jumpRef(FWFTextBlockModule _module)
    {
        Args                args;
        FormRun             formRun;
        FWFTextBlockTable   textBlockTable;
        ;
    
        textBlockTable = FWFTextBlockTable::findNameModule(this.Name, _module);
    
        args = new Args(formstr(FWFTextBlockTable));
        args.lookupRecord(textBlockTable);
        formRun = classfactory.formRunClass(args);
        formRun.init();
        formRun.run();
        formRun.wait();
    }

]]></Source>
			</Method>
			<Method>
				<Name>find</Name>
				<Source><![CDATA[
    public static FWFTextBlockTransParm find(
        RecId       _recId,
        boolean     _forUpdate = false)
    {
        FWFTextBlockTransParm  parm;
    
        parm.selectForUpdate(_forUpdate);
    
        if (_recId)
        {
            select firstonly parm
                where parm.RecId == _recId;
        }
    
        return parm;
    }

]]></Source>
			</Method>
			<Method>
				<Name>initFromPurchSalesAgreement</Name>
				<Source><![CDATA[
    /// <summary>
    /// Initializes some fields depending on <c>Common</c> table parameter.
    /// </summary>
    /// <param name = "_target">A <c>Common</c> table. Table should be <c>AgreementLine</c>, <c>SalesAgreementHeader</c> or <c>PurchAgreementHeader</c> table.</param>
    public void initFromPurchSalesAgreement(Common _target)
    {
        AgreementLine agreementLine;
        SalesAgreementHeader salesAgreementHeader;
        PurchAgreementHeader purchAgreementHeader;

        if (_target.TableId == tableNum(AgreementLine))
        {
            agreementLine = AgreementLine::find(_target.RecId);
            salesAgreementHeader = agreementLine.salesAgreementHeader();
            purchAgreementHeader = agreementLine.purchAgreementHeader();
        }

        if (_target.TableId == tableNum(SalesAgreementHeader) || salesAgreementHeader)
        {
            this.PrintOnSalesConfirmation = NoYes::No;
            this.PrintOnSalesInvoice = NoYes::No;
            this.PrintOnSalesPackingSlip = NoYes::No;
            this.PrintOnSalesPickingList = NoYes::No;
        }

        if (_target.TableId == tableNum(PurchAgreementHeader) || purchAgreementHeader)
        {
            this.PrintOnPurchConfirmation = NoYes::No;
            this.PrintOnPurchInvoice = NoYes::No;
            this.PrintOnPurchPackingSlip = NoYes::No;
            this.PrintOnPurchReceiptsList = NoYes::No;
        }
    }

]]></Source>
			</Method>
