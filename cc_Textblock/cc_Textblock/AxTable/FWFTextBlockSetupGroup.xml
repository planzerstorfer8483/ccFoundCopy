]]></Declaration>
		<Methods>
			<Method>
				<Name>find</Name>
				<Source><![CDATA[
    public static FWFTextBlockSetupGroup find(
        RefRecId    _recId,
        boolean     _update = false)
    {
        FWFTextBlockSetupGroup  setupGroup;

        setupGroup.selectForUpdate(_update);
    
        if (_recId)
        {
            select firstonly setupGroup
                where setupGroup.RecId == _recId;
        }

        return setupGroup;
    }

]]></Source>
			</Method>
			<Method>
				<Name>findGroupModule</Name>
				<Source><![CDATA[
	public static FWFTextBlockSetupGroup findGroupModule(
        FWFTextBlockSetupGroupId	_groupId,
        FWFTextBlockModule			_module,
        boolean						_forUpdate = false)
    {
        FWFTextBlockSetupGroup  setupGroup;
    
        setupGroup.selectForUpdate(_forUpdate);
    
        if (_groupId && _module)
        {
            select firstonly setupGroup
                where setupGroup.GroupId == _groupId
				   && setupGroup.Module  == _module;
        }
    
        return setupGroup;
    }

]]></Source>
			</Method>
		</Methods>
