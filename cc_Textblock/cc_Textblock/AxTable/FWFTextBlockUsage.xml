			<Method>
				<Name>hasTextBlock</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public static boolean hasTextBlock(Common _common, FWFTextBlockAccountRelationType _type)
    {
        boolean			  ret = false;
        FWFTextBlockUsage usage;
        CustVendTable	  custVendTable = _common as CustVendTable;

        select firstonly usage
            where usage.AccountType		== _type
               && usage.AccountCode		== TableGroupAll::Table
               && usage.AccountRelation == custVendTable.AccountNum;

        if (usage)
        {
            ret = true;
        }

        return ret;
    }

]]></Source>
