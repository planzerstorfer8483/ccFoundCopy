			<Method>
				<Name>setupGroup</Name>
				<Source><![CDATA[
    public FWFTextBlockSetupGroup setupGroup()
    {
        FWFTextBlockModule	module;

        if (this.ProductType == FWFTextBlockProductType::None)
        {
            switch (this.AccountType)
            {
                case FWFTextBlockAccountRelationType::Cust :
                    module = FWFTextBlockModule::Customer;
                    break;

                case FWFTextBlockAccountRelationType::Vend :
                    module = FWFTextBlockModule::Supplier;
                    break;

                case FWFTextBlockAccountRelationType::Proj :
                    module = FWFTextBlockModule::Project;
                    break;
            }
        }
        else
        {
            module = FWFTextBlockModule::ReleasedProduct;
        }

        return FWFTextBlockSetupGroup::findGroupModule(this.SetupGroupId, module);
    }

]]></Source>
