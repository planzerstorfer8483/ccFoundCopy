			<Method>
				<Name>validateField</Name>
				<Source><![CDATA[
    boolean  validateField(fieldId  fieldId)
    {
        boolean  ok = true;
    
        switch(fieldId)
        {
            case(fieldNum(FWFTextBlockUsage, FromDate)) :
            case(fieldNum(FWFTextBlockUsage, ToDate))   :
                ok = this.checkDate();
                break;
            case(fieldNum(FWFTextBlockUsage, ItemRelation)) :
                ok = this.checkItemRelation();
                break;
            case(fieldNum(FWFTextBlockUsage, AccountRelation)) :
                ok = this.checkAccountRelation();
                break;
            case(fieldNum(FWFTextBlockUsage, TextBlockRecId)) :
                ok = super(fieldId);
                if (ok)
                {
                    ok = this.checkTextBlockTable();
                }
                break;
            default :
                ok = super(fieldId);
        }
    
        return ok;
    }

]]></Source>
			</Method>
			<Method>
				<Name>validateWrite</Name>
				<Source><![CDATA[
    boolean  validateWrite()
    {
        boolean  ok = true;
    
        ok = super();
    
        if (! this.checkDate())
        {
            ok = false;
        }
    
        if (! this.checkItemRelation())
        {
            ok = false;
        }
    
        if (! this.checkAccountRelation())
        {
            ok = false;
        }
    
        return ok;
    }

]]></Source>
