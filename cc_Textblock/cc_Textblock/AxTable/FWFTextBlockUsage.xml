                    ret = FWFTextBlockModule::Customer;
                    break;

                case FWFTextBlockAccountRelationType::Vend :
                    ret = FWFTextBlockModule::Supplier;
                    break;

                case FWFTextBlockAccountRelationType::Proj :
                    ret = FWFTextBlockModule::Project;
                    break;
            }
        }
        else
        {
            ret = FWFTextBlockModule::ReleasedProduct;
        }

        return ret;
        
    }

]]></Source>
