			<Method>
				<Name>checkAccountRelation</Name>
				<Source><![CDATA[
    boolean  checkAccountRelation()
    {
        boolean  ok = true;
    
        switch(this.AccountCode)
        {
            case TableGroupAll::Table   :
                switch (this.AccountType)
                {
                    case FWFTextBlockAccountRelationType::Cust:
                        if (!CustTable::exist(this.AccountRelation))
                        {
                            ok = checkFailed("@SYS17074");
                        }
                        break;

                    case FWFTextBlockAccountRelationType::Vend:
                        if (!VendTable::exist(this.AccountRelation))
                        {
                            ok = checkFailed("@SYS17074");
                        }
                        break;

                    case FWFTextBlockAccountRelationType::Proj:
                        if (!ProjTable::exist(this.AccountRelation))
                        {
                            ok = checkFailed("@SYS17074");
                        }
                        break;
                }

                break;
    
            case TableGroupAll::GroupId :
                switch (this.AccountType)
                {
                    case FWFTextBlockAccountRelationType::Cust:
                        if (!FWFTextBlockGroup::exist(this.AccountRelation, FWFTextBlockModule::Customer))
                        {
                            ok = checkFailed("@SYS17074");
                        }
                        break;

                    case FWFTextBlockAccountRelationType::Vend:
                        if (!FWFTextBlockGroup::exist(this.AccountRelation, FWFTextBlockModule::Supplier))
                        {
                            ok = checkFailed("@SYS17074");
                        }
                        break;

                    case FWFTextBlockAccountRelationType::Proj:
                        if (!FWFTextBlockGroup::exist(this.AccountRelation, FWFTextBlockModule::Project))
                        {
                            ok = checkFailed("@SYS17074");
                        }
                        break;
                }
                break;
    
            case TableGroupAll::All     :
                if (this.AccountRelation)
                {
                    ok = checkFailed("@SYS17074");
                }
                break;
        }
    
        return ok;
    }

]]></Source>
			</Method>
			<Method>
				<Name>checkDate</Name>
				<Source><![CDATA[
    boolean  checkDate()
    {
        boolean  ok = true;
    
        if (this.ToDate  < this.FromDate)
        {
            if (this.ToDate)
            {
                ok = checkFailed("@SYS16982");
            }
        }
    
        return ok;
    }

]]></Source>
			</Method>
			<Method>
				<Name>checkItemRelation</Name>
				<Source><![CDATA[
    boolean  checkItemRelation()
    {
        boolean  ok = true;
    
        switch(this.ItemCode)
        {
            case TableGroupAll::Table       :
                if (! InventTable::exist(this.ItemRelation))
                {
                    ok = checkFailed("@SYS17075");
                }
                ok = ok && this.checkProductDimensions();
                break;
    
            case TableGroupAll::GroupId     :
                if (! FWFTextBlockGroup::exist(this.ItemRelation, FWFTextBlockModule::ReleasedProduct))
                {
                    ok = checkFailed("@SYS17075");
                }
                break;
    
            case TableGroupAll::All         :
                if (this.ItemRelation)
                {
                    ok = checkFailed("@SYS17075");
                }
                break;
        }
    
        return ok;
    }

]]></Source>
			</Method>
			<Method>
				<Name>checkProductDimensions</Name>
				<Source><![CDATA[
    boolean  checkProductDimensions()
    {
        if (this.ItemCode != TableGroupAll::Table || ! this.ItemRelation)
        {
            return true;
        }
    
        return this.inventDim().validateWriteProductDimensions(this.ItemRelation,false);
    }

]]></Source>
			</Method>
			<Method>
				<Name>checkTextBlockTable</Name>
				<Source><![CDATA[
    public boolean checkTextBlockTable()
    {
        FWFTextBlockTable   textBlockTable = FWFTextBlockTable::find(this.TextBlockRecId);
    
        if (! textBlockTable.isValidForCompany(this.dataAreaId))
        {
            return checkFailed(strFmt("@FWFTextBlock:ErrorTextBlockCannotBeUsedMsg", "@SYS89809", textBlockTable.CompanyId));
        }
    
        return true;
    }

]]></Source>
			</Method>
			<Method>
				<Name>custVendName</Name>
				<Source><![CDATA[
    //BP Deviation documented
    server display Name custVendName()
    {
        Name name;
    
        switch (this.AccountCode)
        {
            case TableGroupAll::Table:
                switch (this.AccountType)
                {
                    case FWFTextBlockAccountRelationType::Cust:
                        name = CustTable::find(this.AccountRelation).name();
                        break;
                    case FWFTextBlockAccountRelationType::Vend:
                        name = VendTable::find(this.AccountRelation).name();
                        break;
                    case FWFTextBlockAccountRelationType::Proj:
                        name = ProjTable::find(this.AccountRelation).Name;
                        break;
                }
                break;
            case TableGroupAll::GroupId:
                switch (this.AccountType)
                {
                    case FWFTextBlockAccountRelationType::Cust:
                        name = FWFTextBlockGroup::findGroupModule(this.AccountRelation, FWFTextBlockModule::Customer).Description;
                        break;
                    case FWFTextBlockAccountRelationType::Vend:
                        name = FWFTextBlockGroup::findGroupModule(this.AccountRelation, FWFTextBlockModule::Supplier).Description;
                        break;
                }
                break;
        }
        return name;
    }

]]></Source>
