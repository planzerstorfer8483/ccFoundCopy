		<Methods>
			<Method>
				<Name>editValue</Name>
				<Source><![CDATA[
    public edit Notes editValue(boolean _set = false, Notes _text = '')
    {
        FWFTextBlockInstance instance;
    
        if (! this.isNewRecord())
        {
            select firstOnly forUpdate instance
                where instance.RefRecId   == this.RecId
                   && instance.RefTableId == this.TableId;
        }
    
        if (_set && ! instance)
        {
            if (! this.validateWrite())
            {
                return '';
            }
            this.write();
    
            if (! instance)
            {
                instance.initValue();
                instance.RefTableId = this.TableId;
                instance.RefRecId   = this.RecId;
                instance.insert();
            }
        }
    
        return instance.editValue(_set, _text);
    }

]]></Source>
			</Method>
			<Method>
				<Name>htmlText</Name>
				<Source><![CDATA[
    public str htmlText()
    {
        FWFTextBlockInstance instance;
        FWFTextBlockValue    value;
    
        select firstOnly RecId from instance
            where instance.RefRecId   == this.RecId
               && instance.RefTableId == this.TableId
        join TextBlock from value
            where value.RecId == instance.ValueRecId;
    
        return value.htmlText();
    }

]]></Source>
			</Method>
			<Method>
				<Name>textBlockTable</Name>
				<Source><![CDATA[
    FWFTextBlockTable textBlockTable()
    {
        FWFTextBlockTable       textBlockTable;
        ;
        select firstOnly textBlockTable
            where textBlockTable.RecId == this.TextBlockRecId;
        return textBlockTable;
    }

]]></Source>
			</Method>
			<Method>
				<Name>find</Name>
				<Source><![CDATA[
    public static FWFTextBlockLanguage find(
        FWFTextBlockRecId   _textBlockRecId,
        LanguageId          _languageId,
        boolean             _update = false
        )
    {
        FWFTextBlockLanguage textBlockLanguage;
    
        textBlockLanguage.selectForUpdate(_update);
    
        if (_textBlockRecId && _languageId)
        {
            select firstonly textBlockLanguage
                where textBlockLanguage.TextBlockRecId == _textBlockRecId
                   && textBlockLanguage.LanguageId     == _languageId;
        }
    
        return textBlockLanguage;
    }

]]></Source>
			</Method>
